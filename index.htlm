<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Kang SIM Info</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0a0f1e;
      --border: #1e2d45;
      --accent: #00d4ff;
      --accent2: #0099cc;
      --text: #e8edf5;
      --muted: #6b7a99;
      --card-bg: #141d2e;
      --radius: 14px;
    }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    header {
      width: 100%;
      max-width: 680px;
      padding: 48px 24px 24px;
      text-align: center;
    }
    .logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .logo-icon { font-size: 28px; }
    .logo-text {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 28px;
      font-weight: 800;
      color: var(--text);
    }
    .logo-text .accent { color: var(--accent); }
    .tagline { color: var(--muted); font-size: 14px; }
    main {
      width: 100%;
      max-width: 680px;
      padding: 0 24px 48px;
      flex: 1;
    }
    .search-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      margin-bottom: 24px;
    }
    .search-card label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 10px;
    }
    .search-row { display: flex; gap: 10px; }
    input[type="text"] {
      flex: 1;
      background: var(--bg);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      color: var(--text);
      font-size: 16px;
      padding: 13px 16px;
      outline: none;
      transition: border-color 0.2s;
    }
    input[type="text"]:focus { border-color: var(--accent); }
    input[type="text"]::placeholder { color: var(--muted); }
    button#searchBtn {
      background: var(--accent);
      color: #000;
      border: none;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 700;
      padding: 13px 24px;
      cursor: pointer;
      white-space: nowrap;
    }
    button#searchBtn:hover { background: var(--accent2); color: #fff; }
    .hint { color: var(--muted); font-size: 12px; margin-top: 8px; }
    .result-area {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px;
      margin-bottom: 16px;
      animation: fadeIn 0.25s ease;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .result-area.not-found {
      border-color: #ff4444;
      text-align: center;
      color: #ff6666;
      padding: 36px;
    }
    .nf-icon { font-size: 36px; margin-bottom: 10px; }
    .result-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .result-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .info-item {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
    }
    .info-item.full-width { grid-column: 1 / -1; }
    .info-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.7px;
      margin-bottom: 5px;
    }
    .info-value {
      font-size: 15px;
      font-weight: 500;
      color: var(--text);
      word-break: break-word;
    }
    .info-value.sim-num {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 18px;
      color: var(--accent);
    }
    .network-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
    }
    .net-jazz    { background: #ff5722; color: #fff; }
    .net-telenor { background: #1565c0; color: #fff; }
    .net-zong    { background: #7b1fa2; color: #fff; }
    .net-ufone   { background: #c62828; color: #fff; }
    .net-other   { background: #37474f; color: #fff; }
    .loading { text-align: center; padding: 36px; color: var(--muted); }
    .loading-spinner {
      font-size: 32px;
      animation: spin 1s linear infinite;
      display: block;
      margin-bottom: 12px;
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    .stats-bar {
      text-align: center;
      color: var(--muted);
      font-size: 12px;
      padding: 8px;
    }
    footer {
      width: 100%;
      text-align: center;
      padding: 16px;
      color: var(--muted);
      font-size: 12px;
      border-top: 1px solid var(--border);
    }
    .hidden { display: none !important; }
    @media (max-width: 480px) {
      header { padding: 32px 16px 16px; }
      main { padding: 0 16px 32px; }
      .search-row { flex-direction: column; }
      button#searchBtn { width: 100%; padding: 14px; }
      .info-grid { grid-template-columns: 1fr; }
      .info-item.full-width { grid-column: 1; }
    }
  </style>
</head>
<body>

  <header>
    <div class="logo">
      <span class="logo-icon">📡</span>
      <span class="logo-text">Kang <span class="accent">SIM</span> Info</span>
    </div>
    <p class="tagline">Search SIM number details instantly</p>
  </header>

  <main>
    <div class="search-card">
      <label for="simInput">Enter SIM Number</label>
      <div class="search-row">
        <input
          type="text"
          id="simInput"
          placeholder="e.g. 03001234567"
          maxlength="11"
          inputmode="numeric"
        />
        <button id="searchBtn" onclick="searchSIM()">Search</button>
      </div>
      <p class="hint">Enter 10 or 11 digit Pakistani mobile number</p>
    </div>

    <div id="result" class="hidden"></div>
    <div class="stats-bar">📡 Kang SIM Info — 9 Million Records</div>
  </main>

  <footer>
    <p>Kang SIM Info &copy; 2026 — For authorized use only</p>
    <p style="margin-top:6px;">Developed By : Shehzad Siyal</p>
  </footer>

  <script>
    var SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzaHXbiQ4uIAdG6cyfQUsr61DgElJcf8iGC0freucwH0skZd56C6Q5nFrWWRsAoaxhC/exec';

    document.getElementById('simInput').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') searchSIM();
    });

    function searchSIM() {
      var input = document.getElementById('simInput').value.trim();

      if (!input) {
        showError('Please enter a SIM number.');
        return;
      }

      if (!/^\d{10,11}$/.test(input)) {
        showError('Enter a valid 10 or 11 digit mobile number.');
        return;
      }

      if (SCRIPT_URL === 'PASTE_YOUR_APPS_SCRIPT_URL_HERE') {
        showError('Please set your Apps Script URL in index.html');
        return;
      }

      showLoading();

      fetch(SCRIPT_URL + '?sim=' + encodeURIComponent(input))
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.status === 'found') {
            showResult(d.data, input);
          } else {
            showNotFound(input);
          }
        })
        .catch(function() {
          showError('Connection error. Please try again.');
        });
    }

    function showLoading() {
      var el = document.getElementById('result');
      el.className = 'result-area';
      el.classList.remove('hidden');
      el.innerHTML = '<div class="loading"><span class="loading-spinner">⏳</span>Searching records...</div>';
    }

    function showResult(data, sim) {
      var el = document.getElementById('result');
      el.className = 'result-area';
      el.classList.remove('hidden');
      var name    = data['name'] || data['owner_name'] || '-';
      var cnic    = data['cnic'] || '-';
      var address = data['address'] || '-';
      var network = detectNetwork(sim);
      el.innerHTML =
        '<div class="result-title">📋 SIM Record Found</div>' +
        '<div class="info-grid">' +
        '<div class="info-item full-width"><div class="info-label">SIM Number</div><div class="info-value sim-num">' + x(sim) + '</div></div>' +
        '<div class="info-item"><div class="info-label">Owner Name</div><div class="info-value">' + x(name) + '</div></div>' +
        '<div class="info-item"><div class="info-label">Network</div><div class="info-value">' + badge(network) + '</div></div>' +
        '<div class="info-item full-width"><div class="info-label">CNIC</div><div class="info-value">' + x(cnic) + '</div></div>' +
        '<div class="info-item full-width"><div class="info-label">Address</div><div class="info-value">' + x(address) + '</div></div>' +
        '</div>';
    }

    function showNotFound(sim) {
      var el = document.getElementById('result');
      el.className = 'result-area not-found';
      el.classList.remove('hidden');
      el.innerHTML = '<div class="nf-icon">🔍</div><strong>No record found</strong><p style="margin-top:8px;font-size:13px;color:#888;">' + x(sim) + ' is not in the database.</p>';
    }

    function showError(msg) {
      var el = document.getElementById('result');
      el.className = 'result-area not-found';
      el.classList.remove('hidden');
      el.innerHTML = '<div class="nf-icon">⚠️</div><strong>' + x(msg) + '</strong>';
    }

    function detectNetwork(num) {
      var p = num.substring(0, 4);
      if (['0300','0301','0302','0303','0304','0305','0306','0307','0308','0311','0312','0313','0314','0315','0316','0317','0318','0319'].indexOf(p) !== -1) return 'Jazz';
      if (['0310','0320','0321','0322','0323','0324','0325','0326','0327','0328','0329'].indexOf(p) !== -1) return 'Zong';
      if (['0340','0341','0342','0343','0344','0345','0346','0347','0348','0349'].indexOf(p) !== -1) return 'Telenor';
      if (['0333','0331','0332','0334','0335','0336','0337','0338','0339'].indexOf(p) !== -1) return 'Ufone';
      return 'Unknown';
    }

    function badge(network) {
      var n = network.toLowerCase();
      var c = 'net-other';
      if (n.indexOf('jazz') !== -1) c = 'net-jazz';
      else if (n.indexOf('telenor') !== -1) c = 'net-telenor';
      else if (n.indexOf('zong') !== -1) c = 'net-zong';
      else if (n.indexOf('ufone') !== -1) c = 'net-ufone';
      return '<span class="network-badge ' + c + '">' + x(network) + '</span>';
    }

    function x(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
  </script>
</body>
</html>
